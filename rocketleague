<!DOCTYPE html>
<html lang="eng">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>Rocket League</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&display=swap');
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{width:100%;height:100%;background:#000;font-family:'Barlow Condensed',sans-serif;color:#fff;overflow:hidden}
#menu{position:fixed;inset:0;background:#04080f;display:flex;flex-direction:column;overflow-y:auto;z-index:10}
#game{position:fixed;inset:0;background:#000;display:none;flex-direction:column;z-index:10}
canvas{display:block}
.menu-bg-wrap{position:fixed;inset:0;z-index:0}
#mbg{width:100%;height:100%}
.menu-inner{position:relative;z-index:1;display:flex;flex-direction:column;min-height:100%;padding-bottom:10px}
.logo-wrap{text-align:center;padding:14px 0 5px}
.logo-main{font-size:clamp(24px,6vw,44px);font-weight:900;letter-spacing:5px;background:linear-gradient(90deg,#00c8ff,#fff 45%,#ff6600);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.logo-sub{font-size:9px;letter-spacing:6px;color:rgba(255,255,255,.3);margin-top:1px}
.rank-chip{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:3px 12px;margin-top:6px;font-size:12px;font-weight:700}
.tabs{display:flex;padding:0 10px;gap:2px;border-bottom:1px solid rgba(255,255,255,.08)}
.tab{flex:1;padding:8px 0;text-align:center;font-size:11px;font-weight:700;letter-spacing:2px;color:rgba(255,255,255,.38);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s}
.tab.on{color:#fff;border-bottom-color:#00c8ff}
.panel{display:none;padding:10px;flex-direction:column;gap:8px}
.panel.on{display:flex}
.sec{font-size:8px;letter-spacing:3px;color:rgba(255,255,255,.3);margin-bottom:2px}
.card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:8px;padding:10px 12px;display:flex;flex-direction:column;gap:7px}
.mode-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.mode-btn{position:relative;border-radius:7px;overflow:hidden;cursor:pointer;border:2px solid transparent;aspect-ratio:2.2/1;background:#0a1020;transition:border-color .15s}
.mode-btn.on{border-color:#00c8ff}
.mode-btn-inner{position:absolute;inset:0;padding:8px 10px;display:flex;flex-direction:column;justify-content:flex-end;background:linear-gradient(0deg,rgba(0,0,0,.75),transparent)}
.mode-name{font-size:14px;font-weight:900;letter-spacing:1px}
.mode-desc{font-size:8px;color:rgba(255,255,255,.5);margin-top:1px}
.mode-badge{position:absolute;top:5px;right:5px;font-size:7px;font-weight:700;letter-spacing:1px;padding:2px 5px;border-radius:3px}
.pills{display:flex;gap:4px;flex-wrap:wrap}
.pill{padding:5px 12px;border:1px solid rgba(255,255,255,.1);border-radius:20px;cursor:pointer;font-size:10px;font-weight:700;letter-spacing:1px;color:rgba(255,255,255,.38);transition:all .12s}
.pill.bl{border-color:#00c8ff;color:#00c8ff;background:rgba(0,180,255,.1)}
.pill.or{border-color:#ff6600;color:#ff6600;background:rgba(255,100,0,.1)}
.diff-row{display:flex;gap:5px}
.diff-card{flex:1;border:1px solid rgba(255,255,255,.1);border-radius:7px;padding:8px 6px;text-align:center;cursor:pointer;background:rgba(255,255,255,.02);transition:all .12s}
.diff-card.on{border-color:#00c8ff;background:rgba(0,180,255,.08)}
.diff-card .di{font-size:18px;display:block}
.diff-card .dn{font-size:11px;font-weight:800;letter-spacing:1px;display:block;margin-top:2px}
.diff-card .dd{font-size:8px;color:rgba(255,255,255,.38);display:block;margin-top:1px}
.colors{display:flex;gap:4px;flex-wrap:wrap}
.csw{width:21px;height:21px;border-radius:50%;cursor:pointer;border:2px solid rgba(255,255,255,.15);transition:transform .1s,border-color .1s}
.csw.on{border-color:#fff;transform:scale(1.28)}
.prev-box{height:95px;border-radius:6px;overflow:hidden;background:#060c18;border:1px solid rgba(255,255,255,.07)}
.rank-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.rank-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:7px;padding:10px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:3px}
.rank-card.cur{border-color:#00c8ff;background:rgba(0,180,255,.06)}
.rank-icon{font-size:26px}
.rank-name{font-size:12px;font-weight:800;letter-spacing:2px}
.rank-range{font-size:9px;color:rgba(255,255,255,.38)}
.kw{padding:8px 10px;flex-shrink:0}
.kbtn{width:100%;height:48px;background:linear-gradient(90deg,#0077bb,#00c8ff);border:none;font-family:'Barlow Condensed',sans-serif;font-size:19px;font-weight:900;letter-spacing:5px;color:#fff;cursor:pointer;clip-path:polygon(13px 0,100% 0,calc(100% - 13px) 100%,0 100%);transition:filter .15s}
.kbtn:active{filter:brightness(1.3)}
.res{text-align:center;font-size:18px;font-weight:900;letter-spacing:2px;min-height:22px;padding:3px 0}
/* Multiplayer info box */
.mp-info{background:rgba(0,200,100,.06);border:1px solid rgba(0,200,100,.2);border-radius:8px;padding:10px 12px;font-size:11px;line-height:1.7;color:rgba(255,255,255,.65)}
.mp-info b{color:#00ff88}
/* GAME HUD */
.hud-top{display:flex;align-items:center;justify-content:space-between;padding:0 12px;height:34px;background:rgba(0,0,0,.88);flex-shrink:0}
.hud-score{font-size:20px;font-weight:900;letter-spacing:2px}
.hud-timer{font-size:15px;font-weight:800;letter-spacing:3px;color:#fff}
.hud-timer.low{color:#ff2244;animation:blink .5s infinite alternate}
@keyframes blink{from{opacity:1}to{opacity:.4}}
.hud-bot{display:flex;align-items:center;gap:6px;padding:2px 12px;background:rgba(0,0,0,.78);height:22px;flex-shrink:0}
.boost-lbl{font-size:8px;letter-spacing:2px;color:#ff6600;flex-shrink:0}
.boost-track{flex:1;height:5px;background:rgba(255,255,255,.1);border-radius:3px;overflow:hidden}
.boost-fill{height:100%;border-radius:3px}
.boost-pct{font-size:10px;font-weight:800;min-width:24px;text-align:right;color:#ff6600}
.hud-btn{font-size:8px;font-weight:700;letter-spacing:1px;padding:2px 7px;border:1px solid rgba(255,255,255,.22);border-radius:3px;cursor:pointer;color:rgba(255,255,255,.55);background:transparent;flex-shrink:0;transition:all .12s}
.hud-btn.on{border-color:#00c8ff;color:#00c8ff;background:rgba(0,180,255,.1)}
.hud-btn.exit{border-color:rgba(255,80,80,.4);color:rgba(255,100,100,.8)}
/* P2 HUD */
.p2-hud{display:none;align-items:center;gap:6px;padding:2px 12px;background:rgba(0,0,0,.7);height:20px;flex-shrink:0;border-top:1px solid rgba(255,100,0,.2)}
.p2-hud.visible{display:flex}
.p2-boost-lbl{font-size:8px;letter-spacing:2px;color:#ff6600;flex-shrink:0}
.p2-boost-track{width:100px;height:4px;background:rgba(255,255,255,.1);border-radius:3px;overflow:hidden}
.p2-boost-fill{height:100%;border-radius:3px;background:#ff6600}
.p2-label{font-size:8px;color:rgba(255,255,255,.4);margin-left:4px}
#goal-ov{position:fixed;inset:0;display:none;flex-direction:column;align-items:center;justify-content:center;z-index:80;pointer-events:none}
#goal-txt{font-size:clamp(50px,14vw,88px);font-weight:900;letter-spacing:10px;animation:gPop .35s cubic-bezier(.2,1.6,.5,1) both}
#goal-sub{font-size:clamp(13px,3vw,18px);letter-spacing:3px;color:rgba(255,255,255,.7);margin-top:4px}
@keyframes gPop{from{transform:scale(.15);opacity:0}to{transform:scale(1);opacity:1}}
#expl-cv{position:fixed;inset:0;pointer-events:none;z-index:79}
#qchat{position:fixed;bottom:26px;left:50%;transform:translateX(-50%);display:flex;gap:5px;z-index:60}
.qc{padding:5px 12px;background:rgba(0,0,0,.72);border:1px solid rgba(255,255,255,.28);border-radius:4px;font-size:11px;font-weight:700;letter-spacing:1px;cursor:pointer}
.qc:active{background:rgba(255,255,255,.2)}
.chat{position:fixed;left:12px;font-size:11px;font-weight:700;padding:3px 9px;border-radius:4px;pointer-events:none;z-index:70;animation:chatAnim 2.5s forwards}
@keyframes chatAnim{0%{opacity:0;transform:translateY(8px)}10%{opacity:1;transform:none}80%{opacity:1}100%{opacity:0}}
/* TOUCH CONTROLS */
#tc{position:fixed;bottom:24px;left:0;right:0;padding:0 8px;display:none;justify-content:space-between;align-items:flex-end;z-index:55;pointer-events:none}
.dpad{width:108px;height:108px;position:relative;pointer-events:all}
.dp{position:absolute;width:33px;height:33px;background:rgba(255,255,255,.13);border:1px solid rgba(255,255,255,.26);border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:13px;user-select:none}
.dp.on{background:rgba(255,255,255,.3)}
#dpu{top:0;left:37px}#dpd{bottom:0;left:37px}#dpl{top:37px;left:0}#dpr{top:37px;right:0}
.abtns{display:flex;flex-direction:column;gap:5px;align-items:flex-end;pointer-events:all}
.ab{width:48px;height:48px;border-radius:50%;border:2px solid;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:900;user-select:none}
.ab.on{filter:brightness(1.6)}
#ab-b{background:rgba(255,100,0,.28);border-color:#ff6600;color:#ff6600}
#ab-j{background:rgba(0,180,255,.28);border-color:#00c8ff;color:#00c8ff}
/* controls hint */
.ctrl-hint{position:fixed;bottom:24px;right:8px;font-size:8px;color:rgba(255,255,255,.22);text-align:right;line-height:1.7;pointer-events:none;z-index:50}
</style>
</head>
<body>
<div id="menu">
  <div class="menu-bg-wrap"><canvas id="mbg"></canvas></div>
  <div class="menu-inner">
    <div class="logo-wrap">
      <div class="logo-main">ROCKET LEAGUE</div>
      <div class="logo-sub">BROWSER EDITION</div>
      <div class="rank-chip"><span id="ri">🥉</span><span id="rn">BRONZE</span><span style="color:rgba(255,255,255,.35);margin-left:4px" id="rm">0 MMR</span></div>
    </div>
    <div class="tabs">
      <div class="tab on" onclick="showTab('play')">SPELEN</div>
      <div class="tab" onclick="showTab('car')">AUTO</div>
      <div class="tab" onclick="showTab('multi')">MULTIPLAYER</div>
      <div class="tab" onclick="showTab('ranked')">RANKED</div>
    </div>
    <!-- PLAY -->
    <div id="tp-play" class="panel on">
      <div><div class="sec">MODUS</div><div class="mode-grid" id="mgrid"></div></div>
      <div class="card">
        <div class="sec">DUUR</div>
        <div class="pills" id="dur-pills">
          <div class="pill bl" onclick="sp(this,'dur',60)">1 MIN</div>
          <div class="pill" onclick="sp(this,'dur',180)">3 MIN</div>
          <div class="pill" onclick="sp(this,'dur',300)">5 MIN</div>
          <div class="pill" onclick="sp(this,'dur',420)">7 MIN</div>
          <div class="pill" onclick="sp(this,'dur',0)">∞</div>
        </div>
      </div>
      <div class="card">
        <div class="sec">MOEILIJKHEID</div>
        <div class="diff-row">
          <div class="diff-card" onclick="sd2(this,'easy')"><span class="di">😊</span><span class="dn" style="color:#44ff88">EASY</span><span class="dd">Beginners</span></div>
          <div class="diff-card on" onclick="sd2(this,'hard')"><span class="di">😤</span><span class="dn" style="color:#ffaa00">HARD</span><span class="dd">Uitdagend</span></div>
          <div class="diff-card" onclick="sd2(this,'impossible')"><span class="di">💀</span><span class="dn" style="color:#ff2244">IMPOSSIBLE</span><span class="dd">Goed geluk</span></div>
        </div>
      </div>
      <div class="card">
        <div class="sec">STADION</div>
        <div class="pills" id="st-pills">
          <div class="pill bl" onclick="sp(this,'stadium','beckwith')">BECKWITH</div>
          <div class="pill" onclick="sp(this,'stadium','urban')">URBAN</div>
          <div class="pill" onclick="sp(this,'stadium','aquadome')">AQUADOME</div>
          <div class="pill" onclick="sp(this,'stadium','neon')">NEON</div>
          <div class="pill" onclick="sp(this,'stadium','arctic')">ARCTIC</div>
        </div>
      </div>
      <div id="res-txt" class="res"></div>
    </div>
    <!-- CAR -->
    <div id="tp-car" class="panel">
      <div class="card"><div class="sec">CARROSSERIE</div>
        <div class="pills" id="body-pills">
          <div class="pill or" onclick="sp(this,'body','octane')">OCTANE</div>
          <div class="pill" onclick="sp(this,'body','dominus')">DOMINUS</div>
          <div class="pill" onclick="sp(this,'body','fennec')">FENNEC</div>
          <div class="pill" onclick="sp(this,'body','breakout')">BREAKOUT</div>
          <div class="pill" onclick="sp(this,'body','merc')">MERC</div>
        </div>
      </div>
      <div class="card"><div class="sec">AUTO KLEUR</div><div class="colors" id="cc"></div></div>
      <div class="card"><div class="sec">WIEL KLEUR</div><div class="colors" id="wc"></div></div>
      <div class="card"><div class="sec">WIEL STIJL</div>
        <div class="pills" id="ws-pills">
          <div class="pill or" onclick="sp(this,'wStyle','standard')">STANDARD</div>
          <div class="pill" onclick="sp(this,'wStyle','blade')">BLADE</div>
          <div class="pill" onclick="sp(this,'wStyle','deep')">DEEP DISH</div>
          <div class="pill" onclick="sp(this,'wStyle','lowrider')">LOWRIDER</div>
        </div>
      </div>
      <div class="card"><div class="sec">BOOST KLEUR</div><div class="colors" id="bc"></div></div>
      <div class="card"><div class="sec">DECAL</div>
        <div class="pills" id="dec-pills">
          <div class="pill or" onclick="sp(this,'decal','none')">GEEN</div>
          <div class="pill" onclick="sp(this,'decal','stripes')">STREPEN</div>
          <div class="pill" onclick="sp(this,'decal','flames')">VLAMMEN</div>
          <div class="pill" onclick="sp(this,'decal','lightning')">BLIKSEM</div>
        </div>
      </div>
      <div class="prev-box"><canvas id="pvc" width="400" height="95"></canvas></div>
    </div>
    <!-- MULTIPLAYER -->
    <div id="tp-multi" class="panel">
      <div class="mp-info">
        <b>Lokale Multiplayer — 2 spelers op 1 apparaat</b><br><br>
        Speler 1 (Blauw): <b>W/S/A/D</b> rijden · <b>Space</b> springen · <b>Q</b> boost<br>
        Speler 2 (Oranje): <b>Pijltjes</b> rijden · <b>Enter</b> springen · <b>/</b> boost<br><br>
        Op touchscreen: Speler 1 gebruikt de linker D-pad, Speler 2 de rechter knoppen.
      </div>
      <div class="card">
        <div class="sec">SPELER 2 AUTO KLEUR</div>
        <div class="colors" id="p2cc"></div>
      </div>
      <div class="card">
        <div class="sec">MODUS</div>
        <div class="pills" id="mp-pills">
          <div class="pill bl" onclick="sp(this,'mpMode','1v1')">1v1 LOCAL</div>
          <div class="pill" onclick="sp(this,'mpMode','2v2local')">2v2 LOCAL</div>
        </div>
      </div>
    </div>
    <!-- RANKED -->
    <div id="tp-ranked" class="panel">
      <div class="card"><div class="sec">JOUW RANK</div><div class="rank-grid" id="rg"></div></div>
      <div class="card" style="gap:3px">
        <div class="sec">HOE HET WERKT</div>
        <div style="font-size:10px;color:rgba(255,255,255,.42);line-height:1.7">Win: +25 MMR &nbsp;|&nbsp; Verlies: -20 MMR<br>Ranked alleen in 1v1 modus.</div>
      </div>
    </div>
  </div>
  <div class="kw"><button class="kbtn" id="kbtn" onclick="startGame()">⚡ KICKOFF</button></div>
</div>

<div id="game">
  <div class="hud-top">
    <div style="display:flex;align-items:center;gap:7px">
      <span style="font-size:10px;font-weight:700;letter-spacing:2px;opacity:.6" id="ht-bl">BLAUW</span>
      <span class="hud-score" id="hs-bl" style="color:#00c8ff">0</span>
    </div>
    <div style="display:flex;flex-direction:column;align-items:center">
      <div class="hud-timer" id="htim">1:00</div>
      <div style="font-size:8px;color:rgba(255,255,255,.28);letter-spacing:2px" id="hmod">1v1</div>
    </div>
    <div style="display:flex;align-items:center;gap:7px">
      <span class="hud-score" id="hs-or" style="color:#ff6600">0</span>
      <span style="font-size:10px;font-weight:700;letter-spacing:2px;opacity:.6" id="ht-or">ORANJE</span>
    </div>
  </div>
  <canvas id="gc"></canvas>
  <div class="hud-bot">
    <span class="boost-lbl">P1 BOOST</span>
    <div class="boost-track"><div class="boost-fill" id="bfill" style="width:100%;background:#ff6600"></div></div>
    <span class="boost-pct" id="bpct">100</span>
    <div class="hud-btn" id="bcam-btn" onclick="toggleBallcam()">BALLCAM</div>
    <div class="hud-btn exit" onclick="exitGame()">EXIT</div>
  </div>
  <div class="p2-hud" id="p2hud">
    <span class="p2-boost-lbl">P2 BOOST</span>
    <div class="p2-boost-track"><div class="p2-boost-fill" id="p2bfill" style="width:100%"></div></div>
    <span class="p2-label">P2: Pijltjes + Enter + /</span>
  </div>
  <div id="qchat">
    <div class="qc" onclick="doChat('What a save!')">What a save!</div>
    <div class="qc" onclick="doChat('Close one!')">Close one!</div>
    <div class="qc" onclick="doChat('Nice shot!')">Nice shot!</div>
  </div>
  <div id="goal-ov"><div id="goal-txt">GOAL!</div><div id="goal-sub"></div></div>
  <canvas id="expl-cv"></canvas>
  <div id="tc">
    <div class="dpad">
      <div class="dp" id="dpu">▲</div><div class="dp" id="dpd">▼</div>
      <div class="dp" id="dpl">◀</div><div class="dp" id="dpr">▶</div>
    </div>
    <div class="abtns">
      <div class="ab" id="ab-b">BOOST</div>
      <div class="ab" id="ab-j">JUMP</div>
    </div>
  </div>
  <div class="ctrl-hint">P1: WASD+Space+Q &nbsp;|&nbsp; P2: Pijltjes+Enter+/</div>
</div>

<script>
// ═══════════════════ CONFIG ═══════════════════
const C={mode:'1v1',dur:60,body:'octane',carCol:'#00c8ff',wCol:'#888',wStyle:'standard',boostCol:'#ff8800',decal:'none',difficulty:'hard',stadium:'beckwith',ballcam:false,mpMode:'1v1',p2Col:'#ff6600',multiplayer:false};
const RANKS=[{n:'BRONZE',i:'🥉',c:'#cd7f32',lo:0,hi:99},{n:'SILVER',i:'🥈',c:'#c0c0c0',lo:100,hi:249},{n:'GOLD',i:'🥇',c:'#ffd700',lo:250,hi:499},{n:'DIAMOND',i:'💎',c:'#44ddff',lo:500,hi:9999}];
let mmr=+(localStorage.getItem('rl_mmr')||0);
const MODES=[
  {id:'1v1',n:'1v1',d:'Één tegen één',b:'RANKED',bc:'#ffd700',bg:'#001830',tc:[1,1]},
  {id:'2v2',n:'2v2',d:'Twee tegen twee',b:'TEAM',bc:'#8844ff',bg:'#180010',tc:[2,2]},
  {id:'3v3',n:'3v3',d:'Drie tegen drie',b:'STD',bc:'#ff6600',bg:'#181000',tc:[3,3]},
  {id:'heatseeker',n:'HEATSEEKER',d:'Bal zoekt doel',b:'SPEC',bc:'#ff9900',bg:'#180800',tc:[1,1]},
  {id:'snowday',n:'SNOW DAY',d:'Hockey puck',b:'NIEUW',bc:'#00ddff',bg:'#001820',tc:[1,1]},
  {id:'hoops',n:'HOOPS',d:'Basketbal modus',b:'FUN',bc:'#ff8800',bg:'#180800',tc:[1,1]},
];
const CC=['#00c8ff','#ff3366','#33ff99','#ffdd00','#cc44ff','#ff6600','#fff','#ff1111','#00ff88','#ff88cc'];
const WC=['#888','#00c8ff','#ff6600','#ccc','#ffdd00','#fff','#222','#ff3366'];
const BC=['#ff8800','#00c8ff','#ff3366','#ffdd00','#cc44ff','#00ff88','#fff'];
const STADS={
  beckwith:{st:'#0a0a1a',sb:'#1a0a2a',fc:'#1a5e20',wc:'#1a2040',fl:'rgba(255,255,255,.24)',lc:'rgba(200,150,255,.28)'},
  urban:   {st:'#0d0d0d',sb:'#1a1a2a',fc:'#1e5518',wc:'#2a2a2a',fl:'rgba(255,200,0,.2)',lc:'rgba(255,200,0,.22)'},
  aquadome:{st:'#001825',sb:'#003040',fc:'#186055',wc:'#004455',fl:'rgba(0,200,255,.28)',lc:'rgba(0,200,255,.3)'},
  neon:    {st:'#0a001a',sb:'#1a0030',fc:'#1a0a30',wc:'#200025',fl:'rgba(255,0,255,.32)',lc:'rgba(255,0,255,.35)'},
