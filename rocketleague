  exPts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=.38;p.life-=.024;p.rot+=.08;if(p.life<=0)return;ectx.save();ectx.globalAlpha=p.life;ectx.translate(p.x,p.y);ectx.rotate(p.rot);ectx.fillStyle=p.col;ectx.fillRect(-p.r/2,-p.r/2,p.r,p.r);ectx.restore();});
  exPts=exPts.filter(p=>p.life>0);
}

// ═══ DRAW ARENA ═══
function poly(pts){CTX.beginPath();pts.forEach((p,i)=>i?CTX.lineTo(p.x,p.y):CTX.moveTo(p.x,p.y));CTX.closePath();}

function drawArena(gs){
  const st=STADS[C.stadium];
  const g=CTX.createLinearGradient(0,0,0,GH);g.addColorStop(0,st.st);g.addColorStop(1,st.sb);
  CTX.fillStyle=g;CTX.fillRect(0,0,GW,GH);
  for(let i=0;i<42;i++){CTX.fillStyle=`rgba(255,255,255,${.05+.1*(i%3)/2})`;CTX.fillRect((i*193)%GW,(i*109)%(GH*.38),1,1);}

  // ── BACK WALL (far, high +X = orange territory, no goal) ──
  // Actually with goals on left/right, the back wall is at high X (behind blue team)
  // Far wall = -X side (behind orange)
  const farWall=[w2s(-FW2,-FH2,0),w2s(-FW2,FH2,0),w2s(-FW2,FH2,WH),w2s(-FW2,-FH2,WH)];
  poly(farWall);CTX.fillStyle=st.wc;CTX.fill();CTX.strokeStyle=st.fl;CTX.lineWidth=1;CTX.stroke();
  // Wall grid
  for(let wy=-FH2;wy<=FH2;wy+=80){const a=w2s(-FW2,wy,0),b2=w2s(-FW2,wy,WH);CTX.beginPath();CTX.moveTo(a.x,a.y);CTX.lineTo(b2.x,b2.y);CTX.strokeStyle='rgba(255,255,255,.05)';CTX.lineWidth=1;CTX.stroke();}
  for(let wz=0;wz<=WH;wz+=40){const a=w2s(-FW2,-FH2,wz),b2=w2s(-FW2,FH2,wz);CTX.beginPath();CTX.moveTo(a.x,a.y);CTX.lineTo(b2.x,b2.y);CTX.strokeStyle='rgba(255,255,255,.04)';CTX.lineWidth=1;CTX.stroke();}

  // ── BOTTOM WALL (far Y, -Y side) ──
  const botWall=[w2s(-FW2,-FH2,0),w2s(FW2,-FH2,0),w2s(FW2,-FH2,WH),w2s(-FW2,-FH2,WH)];
  poly(botWall);CTX.fillStyle=st.wc;CTX.fill();CTX.strokeStyle=st.fl;CTX.lineWidth=1;CTX.stroke();
  for(let wx=-FW2;wx<=FW2;wx+=80){const a=w2s(wx,-FH2,0),b2=w2s(wx,-FH2,WH);CTX.beginPath();CTX.moveTo(a.x,a.y);CTX.lineTo(b2.x,b2.y);CTX.strokeStyle='rgba(255,255,255,.05)';CTX.lineWidth=1;CTX.stroke();}

  // ── FLOOR ──
  const fc=[w2s(-FW2,-FH2,0),w2s(FW2,-FH2,0),w2s(FW2,FH2,0),w2s(-FW2,FH2,0)];
  poly(fc);CTX.fillStyle=st.fc;CTX.fill();CTX.strokeStyle=st.fl;CTX.lineWidth=2;CTX.stroke();
  // Field stripes (along X axis)
  for(let i=0;i<7;i++){const xa=-FW2+i*(FW/7),xb=xa+FW/14;poly([w2s(xa,-FH2,0),w2s(xb,-FH2,0),w2s(xb,FH2,0),w2s(xa,FH2,0)]);CTX.fillStyle='rgba(0,0,0,.06)';CTX.fill();}
  // Center line (vertical - along Y)
  const cl1=w2s(0,-FH2,0),cl2=w2s(0,FH2,0);CTX.beginPath();CTX.moveTo(cl1.x,cl1.y);CTX.lineTo(cl2.x,cl2.y);CTX.strokeStyle=st.fl;CTX.lineWidth=2;CTX.stroke();
  // Center circle
  CTX.beginPath();let ff=true;for(let i=0;i<=32;i++){const a=i/32*Math.PI*2,p=w2s(Math.cos(a)*56,Math.sin(a)*56,0);ff?(CTX.moveTo(p.x,p.y),ff=false):CTX.lineTo(p.x,p.y);}CTX.strokeStyle=st.fl;CTX.lineWidth=1.5;CTX.stroke();
  // Stadium lights
  [[-FW2+8,-FH2+8],[-FW2+8,FH2-8],[FW2-8,-FH2+8],[FW2-8,FH2-8]].forEach(([lx,ly])=>{
    const lp=w2s(lx,ly,WH-4);CTX.beginPath();CTX.arc(lp.x,lp.y,5,0,Math.PI*2);CTX.fillStyle='rgba(255,255,200,.9)';CTX.fill();CTX.beginPath();CTX.arc(lp.x,lp.y,13,0,Math.PI*2);CTX.fillStyle=st.lc;CTX.fill();
  });

  // ── TOP WALL (near Y, +Y side, in front) ──
  const topWall=[w2s(-FW2,FH2,0),w2s(FW2,FH2,0),w2s(FW2,FH2,WH),w2s(-FW2,FH2,WH)];
  poly(topWall);CTX.fillStyle=st.wc;CTX.fill();CTX.strokeStyle=st.fl;CTX.lineWidth=1;CTX.stroke();

  // ── GOALS on LEFT (-X) and RIGHT (+X) ──
  // ORANGE goal: LEFT side (-X). Orange defends it. Blue attacks it. Ball entering = Blue scores.
  // BLUE goal: RIGHT side (+X). Blue defends it. Orange attacks it. Ball entering = Orange scores.
  [
    {gx:-FW2,gd:-GDD,stk:'#ff6600',fc2:'rgba(255,100,0,.22)',label:'ORANGE'}, // left = orange goal
    {gx:FW2, gd: GDD,stk:'#00c8ff',fc2:'rgba(0,150,255,.22)', label:'BLUE'},  // right = blue goal
  ].forEach(({gx,gd,stk,fc2})=>{
    // Goal floor
    poly([w2s(gx,-GWW/2,0),w2s(gx,GWW/2,0),w2s(gx+gd,GWW/2,0),w2s(gx+gd,-GWW/2,0)]);
    CTX.fillStyle=fc2;CTX.fill();CTX.strokeStyle=stk;CTX.lineWidth=1.5;CTX.stroke();
    // Goal posts (vertical at corners)
    [[gx,-GWW/2],[gx,GWW/2],[gx+gd,-GWW/2],[gx+gd,GWW/2]].forEach(([px,py])=>{
      const bot=w2s(px,py,0),top=w2s(px,py,GHH);CTX.beginPath();CTX.moveTo(bot.x,bot.y);CTX.lineTo(top.x,top.y);CTX.strokeStyle=stk;CTX.lineWidth=3;CTX.stroke();
    });
    // Crossbar
    const cb1=w2s(gx,-GWW/2,GHH),cb2=w2s(gx,GWW/2,GHH);CTX.beginPath();CTX.moveTo(cb1.x,cb1.y);CTX.lineTo(cb2.x,cb2.y);CTX.strokeStyle=stk;CTX.lineWidth=3;CTX.stroke();
    // Net lines
    for(let ny2=-GWW/2+15;ny2<GWW/2;ny2+=18){const n1=w2s(gx+gd,ny2,0),n2=w2s(gx+gd,ny2,GHH);CTX.beginPath();CTX.moveTo(n1.x,n1.y);CTX.lineTo(n2.x,n2.y);CTX.strokeStyle=stk+'44';CTX.lineWidth=1;CTX.stroke();}
    // Back wall of goal
    poly([w2s(gx+gd,-GWW/2,0),w2s(gx+gd,GWW/2,0),w2s(gx+gd,GWW/2,GHH),w2s(gx+gd,-GWW/2,GHH)]);
    CTX.fillStyle=fc2;CTX.fill();CTX.strokeStyle=stk;CTX.lineWidth=1.5;CTX.stroke();
  });

  // ── BOOST PADS ──
  gs.pads.forEach(p=>{
    if(p.resp>0){p.resp--;if(p.resp<=0)p.active=true;}
    const pp=w2s(p.x,p.y,1),r=p.big?11:7;
    CTX.beginPath();CTX.ellipse(pp.x,pp.y,r,r*YSC,0,0,Math.PI*2);
    CTX.fillStyle=p.active?(p.big?'rgba(255,210,0,.9)':'rgba(255,140,0,.88)'):'rgba(50,50,50,.44)';CTX.fill();
    if(p.active){CTX.strokeStyle=p.big?'rgba(255,255,180,.78)':'rgba(255,180,80,.7)';CTX.lineWidth=1.5;CTX.stroke();}
  });
}

function drawCar3D(c){
  const sp=w2s(c.x,c.y,c.z);
  const cw=c.bw/2,cl=c.bw*.58,ch=c.bw*.28;
  const cosA=Math.cos(c.ang),sinA=Math.sin(c.ang);
  function lw(lx,ly,lz){return{x:c.x+lx*cosA+ly*sinA,y:c.y-lx*sinA+ly*cosA,z:c.z+lz};}
  const v=[lw(-cw,-cl,0),lw(cw,-cl,0),lw(cw,cl,0),lw(-cw,cl,0),lw(-cw,-cl,ch*2),lw(cw,-cl,ch*2),lw(cw,cl,ch*2),lw(-cw,cl,ch*2)].map(p=>w2s(p.x,p.y,p.z));
  const[cr,cg,cb]=h2r(c.col);
  // 6 faces sorted back-to-front
  const faces=[{i:[0,1,2,3],f:.35},{i:[4,5,6,7],f:1},{i:[0,1,5,4],f:.88},{i:[2,3,7,6],f:.55},{i:[0,3,7,4],f:.68},{i:[1,2,6,5],f:.82}];
  faces.sort((a,bv)=>bv.i.reduce((s,i)=>s+v[i].y,0)-a.i.reduce((s,i)=>s+v[i].y,0));
  faces.forEach(f=>{poly(f.i.map(i=>v[i]));CTX.fillStyle=rgb(cr,cg,cb,f.f);CTX.fill();CTX.strokeStyle='rgba(0,0,0,.18)';CTX.lineWidth=.5;CTX.stroke();});
  // Windshield
  const ws3=[lw(-cw+3,-cl+3,ch*2-1),lw(cw-3,-cl+3,ch*2-1),lw(cw-3,-cl+cl*.42,ch*2+2),lw(-cw+3,-cl+cl*.42,ch*2+2)].map(p=>w2s(p.x,p.y,p.z));
  poly(ws3);CTX.fillStyle='rgba(140,230,255,.58)';CTX.fill();
  const wr3=[lw(-cw+5,-cl+4,ch*2),lw(-cw+9,-cl+4,ch*2),lw(-cw+8,-cl+cl*.34,ch*2+2),lw(-cw+4,-cl+cl*.34,ch*2+2)].map(p=>w2s(p.x,p.y,p.z));
  poly(wr3);CTX.fillStyle='rgba(255,255,255,.22)';CTX.fill();
  // Lights
  const hl1=w2s(lw(-cw+3,-cl,.5).x,lw(-cw+3,-cl,.5).y,lw(-cw+3,-cl,.5).z);
  const hl2=w2s(lw(cw-3,-cl,.5).x,lw(cw-3,-cl,.5).y,lw(cw-3,-cl,.5).z);
  CTX.beginPath();CTX.ellipse(hl1.x,hl1.y,3,2,0,0,Math.PI*2);CTX.fillStyle='rgba(255,255,200,.9)';CTX.fill();
  CTX.beginPath();CTX.ellipse(hl2.x,hl2.y,3,2,0,0,Math.PI*2);CTX.fillStyle='rgba(255,255,200,.9)';CTX.fill();
  const bl1=w2s(lw(-cw+3,cl,.5).x,lw(-cw+3,cl,.5).y,lw(-cw+3,cl,.5).z);
  const bl2=w2s(lw(cw-3,cl,.5).x,lw(cw-3,cl,.5).y,lw(cw-3,cl,.5).z);
  CTX.beginPath();CTX.ellipse(bl1.x,bl1.y,3,2,0,0,Math.PI*2);CTX.fillStyle='rgba(255,30,30,.9)';CTX.fill();
  CTX.beginPath();CTX.ellipse(bl2.x,bl2.y,3,2,0,0,Math.PI*2);CTX.fillStyle='rgba(255,30,30,.9)';CTX.fill();
  // 3D Wheels
  const[wr2,wg2,wb2]=h2r(c.wc||'#888');
  [[lw(-cw,-cl*.72,0)],[lw(cw,-cl*.72,0)],[lw(-cw,cl*.72,0)],[lw(cw,cl*.72,0)]].forEach(([wp])=>{
    const wsp=w2s(wp.x,wp.y,wp.z),wt=w2s(wp.x,wp.y,wp.z+ch*.55);
    CTX.beginPath();CTX.arc(wsp.x,wsp.y,5,0,Math.PI*2);CTX.fillStyle='#1a1a1a';CTX.fill();
    CTX.beginPath();CTX.arc(wt.x,wt.y,5,0,Math.PI*2);CTX.fillStyle=rgb(wr2,wg2,wb2);CTX.fill();
    CTX.beginPath();CTX.arc(wt.x,wt.y,1.5,0,Math.PI*2);CTX.fillStyle='#111';CTX.fill();
  });
  // Roof label
  const rt=[lw(-cw+2,-cl+cl*.28,ch*2+1),lw(cw-2,-cl+cl*.28,ch*2+1),lw(cw-2,cl-cl*.28,ch*2+1),lw(-cw+2,cl-cl*.28,ch*2+1)].map(p=>w2s(p.x,p.y,p.z));
  poly(rt);CTX.strokeStyle=c.isP?'rgba(255,255,255,.5)':c.isP2?'rgba(255,200,0,.6)':c.col;CTX.lineWidth=1.5;CTX.stroke();
  // Boost flame
  const boosting=(c.isP&&ik1.b()&&c.boost>0)||(c.isP2&&ik2.b()&&c.boost>0)||(!c.isP&&!c.isP2&&c.spd>AIP[C.difficulty].spd*.88);
  if(boosting){
    const fb=lw(0,cl+5,ch*.5),fs=w2s(fb.x,fb.y,fb.z);
    const[br,bg2,bb]=h2r(c.bc||'#ff8800');
    const fg=CTX.createRadialGradient(fs.x,fs.y,.5,fs.x,fs.y,13);
    fg.addColorStop(0,`rgba(${br},${bg2},${bb},.95)`);fg.addColorStop(.5,`rgba(${~~(br*.6)},${~~(bg2*.2)},0,.7)`);fg.addColorStop(1,'rgba(200,0,0,0)');
    CTX.beginPath();CTX.ellipse(fs.x,fs.y,13,8,0,0,Math.PI*2);CTX.fillStyle=fg;CTX.fill();
  }
}

function drawBall3D(b){
  const sp=w2s(b.x,b.y,0),sr=BLR*Math.max(.25,1-b.z/90);
  CTX.beginPath();CTX.ellipse(sp.x,sp.y,sr*1.1,sr*YSC*.52,0,0,Math.PI*2);CTX.fillStyle=`rgba(0,0,0,${.42*Math.max(.15,1-b.z/75)})`;CTX.fill();
  const pp=w2s(b.x,b.y,b.z),r=BLR;
  const g=CTX.createRadialGradient(pp.x-r*.36,pp.y-r*.36,r*.06,pp.x,pp.y,r);
  g.addColorStop(0,'#fff');g.addColorStop(.22,'#eee');g.addColorStop(.55,'#ccc');g.addColorStop(.82,'#999');g.addColorStop(1,'#555');
  CTX.beginPath();CTX.arc(pp.x,pp.y,r,0,Math.PI*2);CTX.fillStyle=g;CTX.fill();
  CTX.save();CTX.translate(pp.x,pp.y);CTX.rotate(b.spin);
  CTX.strokeStyle='rgba(0,0,0,.18)';CTX.lineWidth=1.2;
  CTX.beginPath();CTX.arc(0,0,r*.62,.4,Math.PI-.4);CTX.stroke();
  CTX.beginPath();CTX.arc(0,r*.3,r*.55,Math.PI+.3,-.3);CTX.stroke();
  CTX.restore();
  CTX.beginPath();CTX.ellipse(pp.x-r*.3,pp.y-r*.3,r*.27,r*.21,-.5,0,Math.PI*2);CTX.fillStyle='rgba(255,255,255,.48)';CTX.fill();
}

function updHUD(gs){
  document.getElementById('hs-bl').textContent=gs.bs;
  document.getElementById('hs-or').textContent=gs.os;
  if(C.dur>0){const m=~~(gs.t/60),s=gs.t%60;const te=document.getElementById('htim');te.textContent=`${m}:${('0'+s).slice(-2)}`;te.classList.toggle('low',gs.t<=15);}
  else document.getElementById('htim').textContent='∞';
}

let chatY=90;
function doChat(msg,opp){
  const el=document.createElement('div');el.className='chat';
  el.style.top=chatY+'px';chatY+=26;if(chatY>210)chatY=90;
  el.style.background=opp?'rgba(200,80,0,.82)':'rgba(0,80,190,.82)';
  el.textContent=(opp?'Oranje: ':'')+msg;
  document.getElementById('game').appendChild(el);
  setTimeout(()=>{el.remove();},2500);
  if(!opp&&Math.random()<.32)setTimeout(()=>doChat(['Nice one!','Wow.','What a save!','Close one!'][~~(Math.random()*4)],true),700+Math.random()*1100);
}
window.doChat=doChat;
function toggleBallcam(){C.ballcam=!C.ballcam;document.getElementById('bcam-btn').classList.toggle('on',C.ballcam);}
function exitGame(){if(GS)GS.running=false;cancelAnimationFrame(RAF);clearInterval(TIV);document.getElementById('game').style.display='none';document.getElementById('menu').style.display='flex';}

let gTimer=null;
function showGoal(team,gs){
  const ov=document.getElementById('goal-ov'),gt=document.getElementById('goal-txt'),gs2=document.getElementById('goal-sub');
  ov.style.display='flex';ov.style.background=team==='blue'?'rgba(0,70,180,.28)':'rgba(200,70,0,.28)';
  gt.style.color=team==='blue'?'#00c8ff':'#ff6600';gt.style.textShadow=`0 0 50px ${team==='blue'?'#00c8ff':'#ff6600'}`;
  gt.textContent='GOAL!';gs2.textContent=team==='blue'?'🔵 BLAUW SCOORT!':'🟠 ORANJE SCOORT!';
  if(gTimer)clearTimeout(gTimer);gTimer=setTimeout(()=>{ov.style.display='none';exPts=[];},2000);
}

function loop(gs){
  if(!gs.running)return;
  resz();updateCamera(gs);CTX.clearRect(0,0,GW,GH);drawArena(gs);
  if(gs.gc>0)gs.gc--;
  else{
    gs.blue.forEach(c=>upCar(c,gs,c.isP?ik1:(c.isP2?ik2:null)));
    gs.orange.forEach(c=>upCar(c,gs,c.isP?ik1:(c.isP2?ik2:null)));
    upBall(gs);
    const g=checkGoal(gs);
    if(g){showGoal(g,gs);updHUD(gs);triggerExplosion(g);spawnAfterGoal(gs);setTimeout(()=>{if(Math.random()<.45)doChat(['What a save!','Nice shot!','Close one!'][~~(Math.random()*3)],true);},500);}
  }
  if(exPts.length>0)tickExplosion();
  const all=[...gs.blue,...gs.orange].sort((a,b)=>a.x-b.x);
  all.forEach(c=>{const sh=w2s(c.x,c.y,0);CTX.beginPath();CTX.ellipse(sh.x,sh.y,18*YSC,18*YSC*.38,0,0,Math.PI*2);CTX.fillStyle=`rgba(0,0,0,${Math.max(0,.4-c.z*.005)})`;CTX.fill();});
  all.forEach(c=>drawCar3D(c));
  drawBall3D(gs.ball);
  RAF=requestAnimationFrame(()=>loop(gs));
}

function endGame(gs){
  cancelAnimationFrame(RAF);clearInterval(TIV);gs.running=false;
  const rb=document.getElementById('res-txt'),blueWon=gs.bs>gs.os;
  if(gs.bs>gs.os){rb.textContent='🔵 BLAUW WINT!';rb.style.color='#00c8ff';}
  else if(gs.os>gs.bs){rb.textContent='🟠 ORANJE WINT!';rb.style.color='#ff6600';}
  else{rb.textContent='⚽ GELIJKSPEL!';rb.style.color='#fff';}
  if(C.mode==='1v1'&&!C.multiplayer){mmr=Math.max(0,mmr+(blueWon?25:-20));localStorage.setItem('rl_mmr',mmr);updateRank();setTimeout(()=>{rb.textContent+=' '+(blueWon?'+25 MMR':'-20 MMR');},400);}
  document.getElementById('kbtn').textContent='⚡ OPNIEUW';
  document.getElementById('game').style.display='none';document.getElementById('menu').style.display='flex';
}

function startGame(){
  cancelAnimationFrame(RAF);clearInterval(TIV);exPts=[];
  // Check if multiplayer tab was selected
  C.multiplayer=document.getElementById('tp-multi').classList.contains('on');
  resz();GS=initGS();
  camX=GS.blue[0]?GS.blue[0].x*0.4:0;camY=0;camTX=camX;camTY=camY;
  document.getElementById('hmod').textContent=C.mode.toUpperCase()+(C.multiplayer?' LOCAL MP':'');
  document.getElementById('menu').style.display='none';
  const gEl=document.getElementById('game');gEl.style.display='flex';
  document.getElementById('goal-ov').style.display='none';
  const p2Hud=document.getElementById('p2hud');
  p2Hud.classList.toggle('visible',C.multiplayer);
  if(isTouch)document.getElementById('tc').style.display='flex';
  updHUD(GS);chatY=90;
  if(C.dur>0){TIV=setInterval(()=>{if(!GS||!GS.running)return;GS.t--;updHUD(GS);if(GS.t<=0){GS.running=false;clearInterval(TIV);endGame(GS);}},1000);}
  loop(GS);
}
window.startGame=startGame;
window.addEventListener('resize',()=>{if(GS&&GS.running)resz();});
</script>
