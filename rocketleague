function initGS(){
  const m=MODES.find(m=>m.id===C.mode)||MODES[0];
  const[nb,no]=m.tc;
  const ys=n=>Array.from({length:n},(_,i)=>((i-(n-1)/2)*55));
  const isMP=C.multiplayer;
  // Blue team: spawn at RIGHT side (+X), facing LEFT (-X direction = ang=PI/2... wait)
  // In our coord system: car ang=0 means forward in -Y direction
  // But our field has goals on left/right (X axis)
  // So we want cars to face toward center (left/right), not up/down
  // Blue (right side, +X) faces left (-X): ang = PI (facing -X = forward in w2s)
  // Orange (left side, -X) faces right (+X): ang = 0
  // Wait - let's define: ang=0 = car faces +Y (screen "up" in iso), 
  // car moves via sin(ang)*spd on X, -cos(ang)*spd on Y
  // To face -X: we need vx = -spd, vy = 0 => sin(ang)=-1,cos(ang)=0 => ang = -PI/2 or 3PI/2
  // To face +X: ang = PI/2
  const blueAng = -Math.PI/2; // face left (-X direction) = toward orange goal
  const orangeAng = Math.PI/2; // face right (+X direction) = toward blue goal

  const blue=ys(nb).map((sy,i)=>makeCar(FW2-65,sy,blueAng,i===0&&!isMP,false,
    i===0?C.carCol:'#1188cc',i===0?C.wCol:'#445',i===0?C.wStyle:'standard',
    i===0?C.body:'octane',i===0?C.decal:'none',i===0?C.boostCol:'#ff8800'));
  const orange=ys(no).map((sy,i)=>{
    const p2=isMP&&i===0;
    return makeCar(-FW2+65,sy,orangeAng,false,p2,
      p2?C.p2Col:'#ff6600',p2?'#888':'#882200','standard','octane','none','#ff8800');
  });
  return{
    ball:{x:0,y:0,z:BLR,vx:(Math.random()-.5)*2.5,vy:(Math.random()-.5)*2,vz:0,spin:0},
    blue,orange,bs:0,os:0,t:C.dur===0?99999:C.dur,gc:0,
    pads:BPADS.map(p=>({...p,active:true,resp:0})),
    hs:C.mode==='heatseeker',running:true,
  };
}

function spawnAfterGoal(gs){
  const blueAng=-Math.PI/2,orangeAng=Math.PI/2;
  const bys=gs.blue.length;
  gs.blue.forEach((c,i)=>{c.x=FW2-65;c.y=((i-(bys-1)/2)*55);c.z=0;c.vx=0;c.vy=0;c.vz=0;c.spd=0;c.ang=blueAng;c.jumpCount=0;c.airTime=0;c.boost=Math.min(100,c.boost+33);});
  const oys=gs.orange.length;
  gs.orange.forEach((c,i)=>{c.x=-FW2+65;c.y=((i-(oys-1)/2)*55);c.z=0;c.vx=0;c.vy=0;c.vz=0;c.spd=0;c.ang=orangeAng;c.jumpCount=0;c.airTime=0;c.boost=Math.min(100,c.boost+33);});
  gs.ball.x=0;gs.ball.y=0;gs.ball.z=BLR;gs.ball.vx=(Math.random()-.5)*2.5;gs.ball.vy=(Math.random()-.5)*2;gs.ball.vz=0;gs.ball._hs=false;
  gs.gc=95;
}

// AI params
const AIP={
  easy:      {spd:3.5,turn:.042,predict:5, err:.4, bth:999},
  hard:      {spd:5.6,turn:.072,predict:14,err:.12,bth:135},
  impossible:{spd:9.0,turn:.13, predict:22,err:.02,bth:55},
};

function aiCtrl(c,gs){
  const p=AIP[C.difficulty];
  const b=gs.ball;
  // Orange goal at -X, Blue goal at +X
  const oppGoalX=c.x>0?-FW2-5:FW2+5;
  const tx=b.x+b.vx*p.predict+(Math.random()-.5)*p.err*45;
  const ty=b.y+b.vy*p.predict+(Math.random()-.5)*p.err*45;
  const ax=tx*.82+oppGoalX*.18, ay=ty;
  // Angle: atan2 for X-based movement
  const tA=Math.atan2(ax-c.x,-(ay-c.y)); // face toward target
  // Actually compute correct angle: we want car to face (ax-cx, ay-cy)
  // Car forward: vx=sin(ang)*spd, vy=-cos(ang)*spd
  // So to go toward (dx,dy): sin(ang)=dx/d, -cos(ang)=dy/d => ang=atan2(dx,-dy) ... wait
  // vx = sin(ang)*spd, vy = -cos(ang)*spd
  // to have vx=dx, vy=dy: sin(ang)=dx/spd, -cos(ang)=dy/spd
  // => ang such that sin(ang)=dx/|d|, cos(ang)=-dy/|d|
  // => ang = atan2(dx, -dy)
  const dx=ax-c.x,dy=ay-c.y;
  const targetAng=Math.atan2(dx,-dy);
  let da=targetAng-c.ang;while(da>Math.PI)da-=Math.PI*2;while(da<-Math.PI)da+=Math.PI*2;
  c.ang+=Math.sign(da)*Math.min(p.turn,Math.abs(da));
  const d=Math.hypot(dx,dy);
  const bst=d>p.bth&&c.boost>25;
  c.boost=bst?Math.max(0,c.boost-1.3):Math.min(100,c.boost+.44);
  c.spd=Math.min(bst?p.spd*1.42:p.spd,c.spd+.28)*.935;
  applyMove(c);
}

function applyMove(c){
  c.vx=Math.sin(c.ang)*c.spd;
  c.vy=-Math.cos(c.ang)*c.spd;
  // Gravity
  if(!c.onG)c.vz-=.43;
  c.z+=c.vz;
  if(c.z<=0){c.z=0;c.vz=0;c.onG=true;c.jumpCount=0;c.airTime=0;}
  if(!c.onG)c.airTime++;
  // Field boundaries with wall riding
  let nx=c.x+c.vx,ny=c.y+c.vy;
  const igX=Math.abs(c.y)<GWW/2; // in goal mouth (Y axis for left/right goals)
  if(nx>FW2-20){c.vx*=-.5;c.spd*=-.5;nx=c.x+c.vx;}
  if(nx<-FW2+20){c.vx*=-.5;c.spd*=-.5;nx=c.x+c.vx;}
  // Goal mouths on left/right, so Y walls are solid everywhere
  if(ny>FH2-20){c.vy*=-.5;c.spd*=-.5;ny=c.y+c.vy;}
  if(ny<-FH2+20){c.vy*=-.5;c.spd*=-.5;ny=c.y+c.vy;}
  c.x=Math.max(-FW2+20,Math.min(FW2-20,nx));
  c.y=Math.max(-FH2+20,Math.min(FH2-20,ny));
}

function upCar(c,gs,inp){
  if(c.isP||c.isP2){
    const ik=inp;
    const acc=ik.w(),brk=ik.s(),lt=ik.a(),rt=ik.d();
    const bst=ik.b()&&c.boost>0;
    const jPressed=ik.j();

    c.boost=bst?Math.max(0,c.boost-1.8):Math.min(100,c.boost+.33);
    const ms=bst?9.5:6.5;
    if(acc) c.spd=Math.min(ms,c.spd+(bst?.62:.32));
    else if(brk) c.spd=Math.max(-4,c.spd-.42);
    else c.spd*=.86;

    if(Math.abs(c.spd)>.1){if(lt)c.ang-=.062;if(rt)c.ang+=.062;}

    // Air control: steer in air too (but slower)
    if(!c.onG){
      if(lt)c.ang-=.028;
      if(rt)c.ang+=.028;
      // Air pitch (affect vz slightly)
      if(acc&&c.airTime>3) c.vz+=0.12;
      if(brk&&c.airTime>3) c.vz-=0.12;
    }

    // Jump & double jump
    if(jPressed&&!c._jHeld){
      if(c.onG&&c.jumpCount===0){
        // First jump
        c.vz=8.5;c.onG=false;c.jumpCount=1;c._jHeld=true;
      } else if(!c.onG&&c.jumpCount===1&&c.airTime>4){
        // Double jump - boost upward and in current direction
        c.vz=Math.max(c.vz,4);
        c.vx+=Math.sin(c.ang)*3;
        c.vy+=-Math.cos(c.ang)*3;
        c.jumpCount=2;c._jHeld=true;
      }
    }
    if(!jPressed)c._jHeld=false;

    if(c.isP){
      const p=c.boost;
      document.getElementById('bfill').style.width=p+'%';
      document.getElementById('bfill').style.background=p>50?C.boostCol:p>20?'#ffaa00':'#ff2244';
      document.getElementById('bpct').textContent=~~p;
    }
    if(c.isP2){
      document.getElementById('p2bfill').style.width=c.boost+'%';
    }
  } else {
    aiCtrl(c,gs);return;
  }
  applyMove(c);
  gs.pads.forEach(p=>{if(!p.active)return;if(Math.hypot(c.x-p.x,c.y-p.y)<(p.big?27:17)){c.boost=Math.min(100,c.boost+(p.big?34:14));p.active=false;p.resp=500;}});
}

function upBall(gs){
  const b=gs.ball;
  if(gs.hs&&b._hs){
    // Orange goal at -X, Blue goal at +X
    const tx=b.vx<0?-FW2-8:FW2+8; // continue in same X direction
    const d=Math.hypot(tx-b.x,-b.y)||1;
    b.vx+=((tx-b.x)/d)*.15;b.vy+=((-b.y)/d)*.08;
    const sp=Math.hypot(b.vx,b.vy);if(sp>10){b.vx=b.vx/sp*10;b.vy=b.vy/sp*10;}
  }
  b.x+=b.vx;b.y+=b.vy;b.z+=b.vz;
  b.vz-=0.16;b.spin+=b.vx*.04;
  if(b.z<=BLR){b.z=BLR;b.vz=Math.abs(b.vz)*.42;if(Math.abs(b.vz)<.22)b.vz=0;}
  b.vx*=.993;b.vy*=.993;
  // Walls - left/right walls have goal openings
  const igY=Math.abs(b.y)<GWW/2;
  if(!igY){
    if(b.x-BLR<-FW2){b.x=-FW2+BLR;b.vx=Math.abs(b.vx)*.76;}
    if(b.x+BLR>FW2){b.x=FW2-BLR;b.vx=-Math.abs(b.vx)*.76;}
  }
  // Top/bottom walls are solid
  if(b.y-BLR<-FH2){b.y=-FH2+BLR;b.vy=Math.abs(b.vy)*.76;}
  if(b.y+BLR>FH2){b.y=FH2-BLR;b.vy=-Math.abs(b.vy)*.76;}
  if(b.z>WH-BLR){b.z=WH-BLR;b.vz=-Math.abs(b.vz)*.58;}
  // Car collisions
  [...gs.blue,...gs.orange].forEach(c=>{
    const dx=b.x-c.x,dy=b.y-c.y,dz=b.z-(c.z+10);
    const d=Math.sqrt(dx*dx+dy*dy+dz*dz),md=BLR+22;
    if(d<md&&d>0){
      const nx=dx/d,ny=dy/d,nz=dz/d;
      const sp=Math.max(4.5,Math.hypot(c.vx,c.vy)*2.0);
      if(gs.hs){
        b._hs=true;
        if(Math.random()<.6){
          // Aim at opponent goal
          const oppX=c.x>0?-FW2-8:FW2+8;
          const dist=Math.hypot(oppX-b.x,-b.y)||1;
          b.vx=((oppX-b.x)/dist)*sp*1.1;b.vy=((-b.y)/dist)*sp*.5;b.vz=3;
        } else{b.vx=nx*sp;b.vy=ny*sp;b.vz=3;}
      } else{
        b.vx=nx*sp+c.vx*.3;b.vy=ny*sp+c.vy*.3;b.vz=Math.max(.8,nz*sp*.5+1.8);
      }
      b.x=c.x+nx*(md+1);b.y=c.y+ny*(md+1);
    }
  });
}

function checkGoal(gs){
  if(gs.gc>0)return null;
  const b=gs.ball,igY=Math.abs(b.y)<GWW/2;
  if(igY&&b.z<GHH){
    // Orange goal at -X: ball enters = BLUE scores
    if(b.x-BLR<-FW2){gs.bs++;return'blue';}
    // Blue goal at +X: ball enters = ORANGE scores
    if(b.x+BLR>FW2){gs.os++;return'orange';}
  }
  return null;
}

// ═══ CAMERA ═══
let camTX=0,camTY=0;
function updateCamera(gs){
  if(!gs.blue[0])return;
  const p=gs.blue[0];
  if(C.ballcam){
    camTX=p.x+(gs.ball.x-p.x)*.3;camTY=p.y+(gs.ball.y-p.y)*.3;
  } else {
    // Camera behind player (behind = higher X since blue is at +X)
    const ahead=18;
    camTX=p.x+Math.sin(p.ang)*ahead;
    camTY=p.y-Math.cos(p.ang)*ahead;
  }
  camX+=(camTX-camX)*.1;camY+=(camTY-camY)*.1;
}

