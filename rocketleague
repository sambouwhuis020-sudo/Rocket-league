// ═══ FIELD LAYOUT ═══
// Goals are on LEFT (-X) and RIGHT (+X) sides
// Field: X goes left/right, Y goes up/down (Y+ = toward player/blue side)
// Blue goal on RIGHT (+X), Orange goal on LEFT (-X)
// So blue attacks left (-X), orange attacks right (+X)
const FW=520, FH=340, FW2=FW/2, FH2=FH/2;
const WH=110; // wall height
// Goal on left/right sides:
const GWW=80;  // goal width (along Y axis)
const GDD=28;  // goal depth (along X axis)
const GHH=75;  // goal height
const BLR=12;  // ball radius

// Boost pads scattered around field
const BPADS=[
  {x:-140,y:-80,big:true},{x:140,y:-80,big:true},
  {x:-140,y:80,big:true},{x:140,y:80,big:true},
  {x:0,y:-100,big:false},{x:0,y:100,big:false},
  {x:-70,y:0,big:false},{x:70,y:0,big:false},
  {x:0,y:0,big:false},
];

// ═══ ISOMETRIC PROJECTION ═══
// Camera sits above the BLUE side (right/+X side), looking toward -X (toward orange goal)
const TILT=0.5, YSC=0.58, ZSC=0.85;
let camX=0,camY=0;

function w2s(wx,wy,wz){
  const rx=wx-camX, ry=wy-camY;
  // Camera looks in +X direction (from blue side toward orange side)
  // So: larger rx = further from camera = higher on screen
  // Screen X: lateral position (Y world axis maps to screen X with tilt)
  const sx=GW/2 + ry - rx*TILT;
  const sy=GH*0.50 + rx*YSC - wz*ZSC;
  return{x:sx,y:sy};
}

